# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Auto-generated state from local tooling / plugins
# .remember/ holds the remember plugin's private session notes — never publish
# .playwright-mcp/ holds Playwright MCP browser cache
.remember/
.playwright-mcp/

# Research output (kept local by default)
*.json
# Exception: preserve historical research artifacts under notes/
# (test run checkpoints, sources.json, etc. — committed as read-only history)
!notes/**/*.json

# Test output
.pytest_cache/
.coverage
htmlcov/
