# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Auto-generated state from local tooling / plugins
# .remember/ holds the remember plugin's private session notes — never publish
# .playwright-mcp/ holds Playwright MCP browser cache
.remember/
.playwright-mcp/

# Research output (kept local by default)
*.json
# Exceptions: preserve historical research artifacts under notes/
# (test run checkpoints, sources.json, etc. — committed as read-only history)
!notes/**/*.json
# Exceptions: preserve TypeScript project configs under cli/
# (without these, fresh clones can't `npm install` or build)
!cli/package.json
!cli/package-lock.json
!cli/tsconfig.json
!cli/tsconfig.test.json
!cli/.prettierrc.json
!cli/launcher-skill/**/*.json
# Exceptions: preserve E2E baseline test outputs (committed for posterity)
!cli/test-runs/v1-baseline/**/*.json

# Test output
.pytest_cache/
.coverage
htmlcov/
