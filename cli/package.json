{
  "name": "deep-research-cli",
  "version": "0.1.0",
  "description": "Deterministic CLI engine for the deep-research pipeline. Orchestrator-as-script with AI calls only for open-ended judgment. Supports Claude Agent SDK and OpenCode (OpenAI-compatible) providers.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/cli.js",
  "bin": {
    "deep-research": "./dist/cli.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:tsc": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.json' '*.md'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "clean": "rm -rf dist coverage .vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "yargs": "^17.7.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/yargs": "^17.0.33",
    "@vitest/coverage-v8": "^2.1.0",
    "esbuild": "^0.24.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
